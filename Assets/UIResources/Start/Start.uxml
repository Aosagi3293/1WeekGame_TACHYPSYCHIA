<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement name="StartContainer" enabled="true" style="flex-grow: 1; -unity-text-align: upper-left; background-color: rgb(92, 151, 137);">
        <ui:Label text="ドロッパー" name="Title" style="-unity-font-style: bold; font-size: 84px; -unity-text-align: middle-center; top: 20%; width: 20%; height: 15%; left: 40%; right: auto; -unity-slice-left: 0; -unity-slice-top: 0; -unity-slice-right: 0; -unity-slice-bottom: 0; display: flex; visibility: visible; overflow: visible;"/>
        <ui:Button text="Start" name="StartButton" style="top: 45%; -unity-font-style: bold; font-size: 48px; width: 20%; height: 10%; left: 40%; -unity-background-image-tint-color: rgb(255, 255, 255); background-color: rgb(70, 105, 208); border-left-color: rgb(106, 100, 100); border-right-color: rgb(106, 100, 100); border-top-color: rgb(106, 100, 100); border-bottom-color: rgb(106, 100, 100); border-top-width: 5px; border-right-width: 5px; border-bottom-width: 5px; border-left-width: 5px;"/>
        <ui:Label text="最終スコア：0" name="Result" style="width: 20%; height: 10%; -unity-text-align: middle-left; font-size: 48px; -unity-font-style: bold; top: 55%; left: 5%;"/>
    </ui:VisualElement>
</ui:UXML>
